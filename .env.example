# ═══════════════════════════════════════════
# Cursor Cline Addition — .env Configuration v2.4
# ═══════════════════════════════════════════
#
# HOW TO USE THIS FILE:
#
# 1. Pick ONE backend below. Uncomment its section, comment out the others.
#
# 2. Three models are ACTIVE at any time:
#    - DEFAULT_MODEL: your daily driver (plain prompts, ask:, agent:)
#    - PLANNING_MODEL: used when you type plan: before your prompt
#    - VISION_MODEL: auto-detected when you include images
#
# 3. To switch models: copy any model ID from the SWAP MENU
#    into DEFAULT_MODEL, save, and restart the proxy. 10 seconds.
#
# ═══════════════════════════════════════════

# ═══════════════════════════════════════════
# OPENROUTER (Cloud Models)
# ═══════════════════════════════════════════

OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_BACKEND=openrouter

DEFAULT_MODEL=deepseek/deepseek-v4-pro
PLANNING_MODEL=deepseek/deepseek-v4-pro
VISION_MODEL=perceptron/perceptron-mk1

# ─── SWAP MENU (reference only) ─────────────────────
# To switch models: copy any ID below into DEFAULT_MODEL
# above, save, and restart the proxy.
#
# deepseek/deepseek-v4-pro      ← DeepSeek V4 Pro (workhorse, 1M context)
# google/gemini-2.5-flash       ← Gemini 2.5 Flash (bulk edits, 1M context)
# moonshotai/kimi-k2.5          ← Kimi K2.5 (critical multi-step, 262K)
# inclusionai/ring-2.6-1t       ← Ring 2.6 1T (deep reasoning, no tools)
# deepseek/deepseek-v4-flash    ← DeepSeek V4 Flash (legacy, cheaper)
# deepseek/deepseek-chat        ← DeepSeek Chat (simple questions, 1M)
# perceptron/perceptron-mk1     ← Perceptron Mk1 (vision, 33K)
# ───────────────────────────────────────────────────

# ═══════════════════════════════════════════
# LOCAL (Ollama, vLLM, LM Studio, etc.)
# ═══════════════════════════════════════════

# LLM_BACKEND=local
# LOCAL_API_URL=http://localhost:11434/v1
# DEFAULT_MODEL=qwen2.5-coder:7b
# PLANNING_MODEL=qwen2.5-coder:14b
# VISION_MODEL=qwen2.5-coder:7b

# ═══════════════════════════════════════════
# DIRECT PROVIDER (Anthropic, OpenAI, Groq, etc.)
# ⚠️  WARNING: No spending cap. You are billed directly.
# ═══════════════════════════════════════════

# LLM_BACKEND=direct
# DIRECT_API_URL=https://api.anthropic.com/v1
# DIRECT_API_KEY=sk-ant-...
# DIRECT_API_PROVIDER=anthropic
# DEFAULT_MODEL=claude-sonnet-4-20250514
# PLANNING_MODEL=claude-sonnet-4-20250514
# VISION_MODEL=claude-sonnet-4-20250514