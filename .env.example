# ═══════════════════════════════════════════
# Cursor Cline Addition — .env Configuration v2.4
# ═══════════════════════════════════════════
#
# HOW TO USE THIS FILE:
#
# 1. Pick your backend below (OpenRouter, local, or direct provider).
#    COMMENT OUT the sections you're NOT using by adding # at the start of each line.
#    UNCOMMENT the section you ARE using by removing # from each line.
#
# 2. To switch models: change DEFAULT_MODEL in your active section,
#    save the file, and restart the proxy. That's it.
#    The new model will be used for everything — no new Cline task needed.
#
# 3. The DEFAULTS section at the bottom must stay as-is.
#    Override any model by uncommenting the line in your active section above.
#
# ⚠️  DO NOT EDIT THE DEFAULTS SECTION AT THE BOTTOM.
# ═══════════════════════════════════════════

# ═══════════════════════════════════════════
# OPENROUTER (Cloud Models)
# ═══════════════════════════════════════════

OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_BACKEND=openrouter

# The models you need to think about:
# DEFAULT_MODEL=deepseek/deepseek-v4-pro     # Your workhorse — used for everything
# PLANNING_MODEL=deepseek/deepseek-v4-pro    # Used when you type plan: prefix
# VISION_MODEL=perceptron/perceptron-mk1     # Used for image detection

# ═══════════════════════════════════════════
# LOCAL (Ollama, vLLM, LM Studio, etc.)
# ═══════════════════════════════════════════

# LLM_BACKEND=local
# LOCAL_API_URL=http://localhost:11434/v1

# DEFAULT_MODEL=qwen2.5-coder:7b
# PLANNING_MODEL=qwen2.5-coder:14b

# ═══════════════════════════════════════════
# DIRECT PROVIDER (Anthropic, OpenAI, Groq, etc.)
# ⚠️  WARNING: No spending cap. You are billed directly.
# ═══════════════════════════════════════════

# LLM_BACKEND=direct
# DIRECT_API_URL=https://api.anthropic.com/v1
# DIRECT_API_KEY=sk-ant-...
# DIRECT_API_PROVIDER=anthropic

# DEFAULT_MODEL=claude-sonnet-4-20250514
# PLANNING_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════════════════
# DEFAULTS — DO NOT EDIT BELOW THIS LINE
# ═══════════════════════════════════════════
#
# These ensure the proxy always has a working configuration.
# Override DEFAULT_MODEL, PLANNING_MODEL, and VISION_MODEL above.
# If a model is removed from OpenRouter, update the value here.

DEFAULT_MODEL=deepseek/deepseek-v4-pro
PLANNING_MODEL=deepseek/deepseek-v4-pro
BULK_MODEL=google/gemini-2.5-flash
RING_MODEL=inclusionai/ring-2.6-1t
VISION_MODEL=perceptron/perceptron-mk1
KIMI_MODEL=moonshotai/kimi-k2.5
V4_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_CHAT_MODEL=deepseek/deepseek-chat