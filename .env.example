# ═══════════════════════════════════════════
# Cursor Cline Addition — .env Configuration v2.3
# ═══════════════════════════════════════════
#
# Two complete configurations below.
# Comment out the block you're NOT using.
# Uncomment the block you ARE using.
#
# ⚠️  DO NOT EDIT THE DEFAULTS SECTION AT THE BOTTOM.
#     Those are fallback values. Override models above.
# ═══════════════════════════════════════════

# ═══════════════════════════════════════════
# OPENROUTER (Cloud Models)
# ═══════════════════════════════════════════

OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_BACKEND=openrouter

# Override any model below (uncomment and edit)
# DEFAULT_MODEL=deepseek/deepseek-v4-pro
# PLANNING_MODEL=deepseek/deepseek-v4-pro
# BULK_MODEL=google/gemini-2.5-flash
# RING_MODEL=inclusionai/ring-2.6-1t
# VISION_MODEL=perceptron/perceptron-mk1
# KIMI_MODEL=moonshotai/kimi-k2.5
# V4_MODEL=deepseek/deepseek-v4-flash
# DEEPSEEK_CHAT_MODEL=deepseek/deepseek-chat

# ═══════════════════════════════════════════
# LOCAL (Ollama, vLLM, LM Studio, etc.)
# ═══════════════════════════════════════════

# LLM_BACKEND=local
# LOCAL_API_URL=http://localhost:11434/v1

# DEFAULT_MODEL=qwen2.5-coder:7b
# PLANNING_MODEL=qwen2.5-coder:14b
# BULK_MODEL=qwen2.5-coder:7b
# RING_MODEL=deepseek-r1:7b
# KIMI_MODEL=qwen2.5-coder:14b
# V4_MODEL=qwen2.5-coder:7b
# DEEPSEEK_CHAT_MODEL=qwen2.5-coder:7b
# VISION_MODEL=llama3.1:8b

# ═══════════════════════════════════════════
# DIRECT PROVIDER (Anthropic, OpenAI, Groq, etc.)
# ⚠️  WARNING: No spending cap. You are billed directly.
# ═══════════════════════════════════════════

# LLM_BACKEND=direct
# DIRECT_API_URL=https://api.anthropic.com/v1
# DIRECT_API_KEY=sk-ant-...
# DIRECT_API_PROVIDER=anthropic

# DEFAULT_MODEL=claude-sonnet-4-20250514
# PLANNING_MODEL=claude-sonnet-4-20250514
# BULK_MODEL=claude-haiku-3-5-20241022
# RING_MODEL=claude-sonnet-4-20250514
# KIMI_MODEL=claude-sonnet-4-20250514
# V4_MODEL=claude-haiku-3-5-20241022
# DEEPSEEK_CHAT_MODEL=claude-haiku-3-5-20241022
# VISION_MODEL=claude-sonnet-4-20250514

# ═══════════════════════════════════════════
# DEFAULTS — DO NOT EDIT BELOW THIS LINE
# ═══════════════════════════════════════════
#
# These ensure the proxy always has a working configuration.
# Override any model in the sections above — do not edit these directly.
# If a model is removed from OpenRouter, update the value here.

DEFAULT_MODEL=deepseek/deepseek-v4-pro
PLANNING_MODEL=deepseek/deepseek-v4-pro
BULK_MODEL=google/gemini-2.5-flash
RING_MODEL=inclusionai/ring-2.6-1t
VISION_MODEL=perceptron/perceptron-mk1
KIMI_MODEL=moonshotai/kimi-k2.5
V4_MODEL=deepseek/deepseek-v4-flash
DEEPSEEK_CHAT_MODEL=deepseek/deepseek-chat